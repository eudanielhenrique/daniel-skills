#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$(dirname "$SCRIPT_DIR")"

echo ""
echo "  daniel-skills"
echo "  -------------"
echo ""

for skill in dh-firestore-backup dh-firestore-restore; do
    target="$SKILLS_DIR/$skill"
    if [ -L "$target" ] || [ -e "$target" ]; then
        rm -rf "$target"
    fi
    ln -s "$SCRIPT_DIR/$skill" "$target"
    echo "  /$skill instalado"
done

echo ""
echo "  Skills instaladas:"
echo ""
echo "    /dh-firestore-backup    Exportar collections do Firestore para JSON"
echo "    /dh-firestore-restore   Restaurar dados do Firestore a partir de JSON"
echo ""
echo "  Pré-requisito:"
echo "    - serviceAccountKey.json na raiz do projeto"
echo ""
echo "  O pacote firestore-export-import é instalado automaticamente ao invocar cada skill."
echo ""
echo "  Pronto."
echo ""
